{% trans_default_domain 'hello' %}
{% extends 'base.html.twig' %}

{% block title %}{{ 'title' | trans }}{% endblock %}

{% block body %}
    <h1 class="text-4xl font-bold text-center p-8 mt-8">
        <span>{{ 'title' | trans }}</span>
    </h1>

    <p>{{ 'subtitle' | trans }}</p>

    <h2 class="mt-5 text-xl">Frontend</h2>

    <ul class="list">
        <li class="list-row items-center">
            <label class="label">
                <input type="checkbox" class="checkbox" />
                <span>{{ "scripts.label" | trans }}</span>
            </label>
            <p class="list-col-grow text-end">
                <button class="btn btn-sm btn-accent" data-hello-btn="">
                    Clicked 0 times
                </button>
            </p>
        </li>
        <li class="list-row">
            <p>
                <label class="label">
                    <input type="checkbox" class="checkbox" />
                    <span>{{ "styles.label" | trans }}</span>
                </label>
            </p>
            <p class="list-col-grow text-end">
                {{ "styles.sentence" | trans }}
            </p>
        </li>
        <li class="list-row">
            <label class="label">
                <input type="checkbox" class="checkbox" />
                <span>{{ "trans.label" | trans }}</span>
            </label>
            <p>
            </p>
            <p class="list-col-grow text-end">
                {{ "trans.sentence" | trans }}
            </p>
        </li>
    </ul>

    <h2 class="mt-5 text-xl">Backend</h2>


    <ul class="list">
        <li class="list-row">
            <label class="label">
                <input type="checkbox" class="checkbox" />
                <span>{{ "auth.label" | trans }}</span>
            </label>
            <p class="list-col-grow text-end">
                {% if app.user %}
                    <span>{{ 'auth.authed' | trans }} {{ app.user.email }}, </span>
                    <a class="link link-primary" href="/logout">{{ "auth.logout" | trans }}</a>
                {% else %}
                    <a class="link link-primary" href="/login">{{ "auth.login" | trans }}</a>
                    or
                    <a class="link link-primary" href="/register">{{ "auth.signup" | trans }}</a>
                {% endif %}
            </p>
        </li>
    </ul>

    <p class="text-center mt-16">
        <a class="btn btn-primary" href="/">Back to symfony home</a>
    </p>
{% endblock %}
